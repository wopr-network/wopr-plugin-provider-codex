{
  "author": "",
  "dependencies": {
    "@openai/codex": "^0.93.0",
    "@openai/codex-sdk": "^0.58.0",
    "winston": "^3.11.0"
  },
  "peerDependencies": {
    "@wopr-network/plugin-types": "^0.2.1",
    "zod": ">=3.0.0"
  },
  "description": "Codex agent SDK provider for WOPR",
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "wopr",
    "wopr-plugin",
    "provider",
    "codex",
    "agent-sdk"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "name": "@wopr-network/wopr-plugin-provider-codex",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "release": {
    "extends": "@wopr-network/semantic-release-config"
  },
  "scripts": {
    "build": "tsc",
    "check": "biome check index.ts tests/ && tsc --noEmit",
    "format": "biome format --write index.ts tests/",
    "lint": "biome check index.ts tests/",
    "lint:fix": "biome check --fix index.ts tests/",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "type": "module",
  "version": "2.0.0",
  "wopr": {
    "plugin": {
      "category": "provider",
      "description": "Codex agent SDK",
      "name": "provider-codex"
    }
  }
}
